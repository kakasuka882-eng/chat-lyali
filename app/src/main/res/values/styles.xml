<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ChatLiyaliZaman" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowNoTitle">false</item>
        <item name="android:windowActionBar">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/secondary</item>
        <item name="android:navigationBarColor">@color/background</item>
        <!-- ActionBar styling -->
        <item name="actionBarStyle">@style/ActionBar.ChatLiyaliZaman</item>
    </style>

    <style name="ActionBar.ChatLiyaliZaman" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.ChatLiyaliZaman.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>
