<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Golden & Light Blue -->
    <style name="Theme.ChatLiyaliZaman" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color - Golden -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <!-- Secondary color - Light Blue -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <!-- Status bar and other colors -->
        <item name="android:statusBarColor">@color/secondary</item>
        <item name="android:navigationBarColor">@color/background</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
